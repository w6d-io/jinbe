            "body": {
              "mode": "raw",
              "raw": "{\n  \"database_type\": \"postgresql\",\n  \"date\": \"2025-10-07T00:00:00Z\",\n  \"size\": \"1.5GB\",\n  \"backupItems\": [\n    {\n      \"database_type\": \"postgresql\",\n      \"name\": \"production_db\",\n      \"admin_username\": \"postgres\",\n      \"username\": \"app_user\",\n      \"filename\": \"production_db_20251007.sql\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/backups?cluster=production-cluster",
              "host": ["{{baseUrl}}"],
              "path": ["backups"],
              "query": [
                {
                  "key": "cluster",
                  "value": "production-cluster",
                  "description": "Cluster name (required)"
                }
              ]
