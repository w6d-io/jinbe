            "description": "Create a new backup with items"
          }
        },
        {
          "name": "Get Backup",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/backups/:id",
              "host": ["{{baseUrl}}"],
              "path": ["backups", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "507f1f77bcf86cd799439011"
