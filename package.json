{
  "name": "jinbe",
  "version": "1.0.0",
  "description": "RBAC control plane — identity groups, service roles, route permissions, OPA policy sync and Oathkeeper rule management",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "jinbe",
    "rbac",
    "oathkeeper",
    "opa",
    "kratos",
    "auth",
    "fastify",
    "kubernetes"
  ],
  "author": "W6D <https://w6d.io>",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@kubernetes/client-node": "^1.4.0",
    "@prisma/client": "^6.18.0",
    "axios": "^1.13.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "moment": "^2.30.1",
    "mustache": "^4.2.0",
    "pg": "^8.11.3",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.3",
    "tar-stream": "^3.1.8",
    "yaml": "^2.8.3",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/mustache": "^4.2.6",
    "@types/node": "^20.11.19",
    "@types/pg": "^8.11.2",
    "@types/supertest": "^6.0.3",
    "@types/tar-stream": "^3.1.4",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitest/coverage-v8": "^1.2.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "prisma": "^6.18.0",
    "supertest": "^6.3.4",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
