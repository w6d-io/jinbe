# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
BASE_URL=http://localhost:3000

# Database (MongoDB — clusters, backups, databases)
DATABASE_URL="mongodb://admin:admin123@localhost:27017/kuma?authSource=admin"

# Dev Mode — bypass auth with fake user
DEV_BYPASS_AUTH=true
DEV_USER_EMAIL=dev@localhost

# Encryption Key for database passwords (min 32 chars)
ENCRYPTION_KEY=your-super-secret-encryption-key-change-this-in-production-min32

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000

# Logging
LOG_LEVEL=info

# API Documentation
ENABLE_SWAGGER=true

# Git commit SHA (optional, for health endpoint)
COMMIT_SHA=

# Kratos (Identity)
KRATOS_PUBLIC_URL=http://auth-w6d-kratos-public:80
KRATOS_ADMIN_URL=http://auth-w6d-kratos-admin:80

# OPA (Policy Engine — queried for admin middleware)
OPA_URL=http://opa:8181

# Application name for OPA authorization context
APP_NAME=jinbe

# Redis (RBAC data store + audit streams)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_AUDIT_STREAM=auth:audit:events

# OPA Data API (direct push — used during migration, will be removed)
OPA_DATA_URL=http://opa:8181

# Service Creation Defaults
SERVICE_DEFAULT_NAMESPACE=default
SERVICE_DEFAULT_DOMAIN=localhost
SERVICE_DEFAULT_PORT=8080

# Git Proxy (LEGACY — only needed for seed:redis migration script)
# GIT_PROXY_API_URL=https://gitlab.w6d.io/api/v4
# GIT_PROXY_PROJECT_ID=infra/k8s/gitops/configs/auth
# GIT_PROXY_ACCESS_TOKEN=your-token
# GIT_PROXY_BRANCH=develop
