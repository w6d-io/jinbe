# ============================================================================
# Jinbe — environment configuration
#
# Copy to `.env` for local development. For production, provide these via
# your secret manager / Helm values / docker-compose env_file.
# Values shown below are dev-friendly defaults — production deployments
# should override every URL and credential.
# ============================================================================

# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
BASE_URL=http://localhost:3000

# ─── Database (MongoDB — clusters, backups, databases) ──────────────────────
DATABASE_URL="mongodb://admin:admin123@localhost:27017/jinbe?authSource=admin"

# ─── Auth bypass (DEV ONLY — never enable in production) ───────────────────
DEV_BYPASS_AUTH=true
DEV_USER_EMAIL=dev@localhost

# ─── Encryption (used for stored DB credentials, ≥ 32 chars) ───────────────
ENCRYPTION_KEY=replace-me-with-a-real-secret-at-least-32-characters-long!

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
# Set DISABLE_CORS=true when an upstream proxy (e.g. Oathkeeper) emits its own
# CORS headers — prevents double Access-Control-Allow-Origin.
DISABLE_CORS=false

# ─── Rate limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000

# ─── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── API documentation ─────────────────────────────────────────────────────
ENABLE_SWAGGER=true

# ─── Build / release metadata (optional) ───────────────────────────────────
COMMIT_SHA=
RELEASE_NAME=
APP_VERSION=

# ─── Kratos (identity provider) ────────────────────────────────────────────
KRATOS_PUBLIC_URL=http://kratos-public:80
KRATOS_ADMIN_URL=http://kratos-admin:80

# ─── OPA / OPAL ────────────────────────────────────────────────────────────
# OPA_URL: where requireAdmin / requireServiceAdmin middleware queries OPA.
OPA_URL=http://opal-client:8181
# OPA_DATA_URL: direct push target for full-dataset refresh.
OPA_DATA_URL=http://opal-client:8181
# OPAL_SERVER_URL: real-time policy/data trigger target.
OPAL_SERVER_URL=http://opal-server:7002
# JINBE_INTERNAL_URL: how opal-server reaches this jinbe instance.
JINBE_INTERNAL_URL=http://jinbe:8080
# OPA_AUTHZ_REMOTE: URL Oathkeeper uses for remote_json authorization checks
# when jinbe generates per-service access rules.
OPA_AUTHZ_REMOTE=http://opa-authz-proxy:8080/v1/data/rbac/allow

# ─── App identity for OPA authorization ────────────────────────────────────
APP_NAME=jinbe

# ─── Redis (RBAC data store + audit streams) ───────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_AUDIT_STREAM=auth:audit:events

# ─── Service creation defaults ─────────────────────────────────────────────
# Used to template upstream URL + match URL when admins POST to /admin/rbac/services.
# Production deployments MUST override these to the cluster's namespace and
# public-facing domain.
SERVICE_DEFAULT_NAMESPACE=default
SERVICE_DEFAULT_DOMAIN=example.com
SERVICE_DEFAULT_PORT=8080

# ─── Bootstrap-generated Oathkeeper rules ──────────────────────────────────
# Upstream URLs for the login UI and admin UI (used to template default
# Oathkeeper rules at bootstrap time).
# LOGIN_UI_URL=http://login-ui:80
# ADMIN_UI_URL=http://admin-ui:80
# Public-facing domains for the three traffic categories (auth = Kratos
# self-service, app = admin UI, api = jinbe). Set in production.
# AUTH_DOMAIN=auth.example.com
# APP_DOMAIN=app.example.com
# API_DOMAIN=api.example.com

# ─── First-run bootstrap admin (optional) ──────────────────────────────────
# Set these only for the very first cluster bootstrap. After bootstrap, leave
# them unset — the seeded admin can manage subsequent users via the API.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=replace-with-a-12-plus-character-password
# ADMIN_NAME=Admin

# ─── Reset guard (DANGEROUS — CLI only) ────────────────────────────────────
# Both must be set to wipe and re-bootstrap. RESET_CONFIRM must equal the
# running image SHA.
JINBE_BOOTSTRAP_DANGEROUS_RESET=false
# JINBE_BOOTSTRAP_RESET_CONFIRM=

# ─── Backup tool (optional — only if /backups feature is used) ─────────────
# Private-registry image URLs for the mongo / postgres backup containers and
# the GCP project for the GCS output bucket.
# BACKUP_IMAGE_MONGO=registry.example.com/backup-tool/mongo:latest
# BACKUP_IMAGE_POSTGRES=registry.example.com/backup-tool/postgres:latest
# BACKUP_GCP_PROJECT_ID=
